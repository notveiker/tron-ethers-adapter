{
  "name": "tron-ethers-adapter",
  "version": "1.0.0",
  "description": "ethers.js v6 compatibility layer for TronWeb — Provider, Signer, and Contract for TRON.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "demo": "ts-node scripts/live-demo.ts",
    "demo:web": "ts-node demo/server/index.ts",
    "test:integration": "jest --config jest.integration.config.js --verbose",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "tron",
    "tronweb",
    "ethers",
    "ethersjs",
    "ethereum",
    "evm",
    "blockchain",
    "adapter",
    "compatibility",
    "web3",
    "dapp"
  ],
  "author": "Tharun Ekambaram",
  "license": "MIT",
  "peerDependencies": {
    "tronweb": ">=5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "cors": "^2.8.6",
    "eslint": "^10.1.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "tronweb": "^5.3.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
